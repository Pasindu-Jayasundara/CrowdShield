# Convex dashboard / CLI: npx convex env set <NAME> <value>

# Shared Azure AI Foundry key (text + image)
AZURE_OPENAI_API_KEY=

# Text scam model
AZURE_OPENAI_ENDPOINT=https://crowedshield.services.ai.azure.com/api/projects/crowedshield/openai/v1/responses
AZURE_OPENAI_MODEL=gpt-4o-2026-08-06.ft-67a5f33f01e745c8946e4ed8740cdb3a-spam-img

# Visual scam model (screenshots) — required for image analysis
AZURE_OPENAI_IMAGE_ENDPOINT=https://crowedshield.services.ai.azure.com/api/projects/crowedshield/openai/v1/responses
AZURE_OPENAI_IMAGE_MODEL=-2025-04-14-ft-afd97a36181944a4be3607494cd1ef77-spam-img-100-100

# Email (SendGrid) — newsletters, announcements, critical alerts
SENDGRID_API_KEY=
SENDGRID_FROM_EMAIL=alerts@yourdomain.com
SENDGRID_FROM_NAME=CrowdShield

# Set all of the above in Convex (not only .env.local):
# npx convex env set AZURE_OPENAI_API_KEY "..."
# Leading "-" requires "--" for the CLI:
# npx convex env set AZURE_OPENAI_IMAGE_MODEL -- "-2025-04-14-ft-afd97a36181944a4be3607494cd1ef77-spam-img-100-100"
# npx convex env set SENDGRID_API_KEY "..."
# npx convex env set SENDGRID_FROM_EMAIL "alerts@yourdomain.com"
